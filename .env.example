# Exemplo de variaveis de ambiente — COPIE para .env e preencha (o .env NAO sobe para o git)
# No Render, configure estas variaveis no painel do servico (Environment).

# Segredo usado para assinar/validar sessoes (gere um valor aleatorio)
SESSION_SECRET=COLOQUE_AQUI_UM_SEGREDO_FORTE

# Intervalo entre bolas (ms). Padrao 3000.
DRAW_INTERVAL=3000

# Tempo de compra/contagem regressiva entre rodadas (ms). Padrao 60000.
INTERMISSION=60000

# Opcional: defina TEST=1 apenas em ambiente de teste para liberar endpoints de teste.
TEST=0

# Chaves de APIs externas (pagamentos, etc.) — preencher conforme necessario.
# PIX_API_KEY=
# PIX_API_SECRET=
